generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  passwordHash  String    @map("password_hash")
  balance       Decimal   @default(100) @db.Decimal(10, 2)
  betsCount     Int       @default(0) @map("bets_count")
  betsWon       Int       @default(0) @map("bets_won")
  roi           Decimal   @default(0) @db.Decimal(10, 2)
  profit        Decimal   @default(0) @db.Decimal(10, 2)
  role          String    @default("USER")
  isBlocked     Boolean   @default(false) @map("is_blocked")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  bets            Bet[]
  groupMembers    GroupMember[]
  notifications   Notification[]
  groupsOwned     Group[]          @relation("GroupAdmin")

  @@map("users")
}

model Group {
  id          String    @id @default(cuid())
  name        String
  inviteCode  String    @unique @map("invite_code")
  adminId     String    @map("admin_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  admin       User          @relation("GroupAdmin", fields: [adminId], references: [id])
  members     GroupMember[]

  @@map("groups")
}

model GroupMember {
  id        String   @id @default(cuid())
  groupId   String   @map("group_id")
  userId    String   @map("user_id")
  joinedAt  DateTime @default(now()) @map("joined_at")

  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("group_members")
}

model Match {
  id            String      @id @default(cuid())
  externalId    String      @unique @map("external_id")
  homeTeam      String      @map("home_team")
  awayTeam      String      @map("away_team")
  homeCrest     String?     @map("home_crest")
  awayCrest     String?     @map("away_crest")
  league        String
  country       String
  matchday      Int?
  groupStage    String?     @map("group_stage")
  matchDate     DateTime    @map("match_date")
  status        String      @default("SCHEDULED")
  homeScore     Int?        @map("home_score")
  awayScore     Int?        @map("away_score")
  halfTimeHome  Int?        @map("half_time_home")
  halfTimeAway  Int?        @map("half_time_away")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  odds          Odds[]
  betSelections BetSelection[]

  @@index([status])
  @@index([matchDate])
  @@map("matches")
}

model Odds {
  id          String   @id @default(cuid())
  matchId     String   @map("match_id")
  market      String
  selection   String
  value       Decimal  @db.Decimal(10, 2)
  source      String   @default("estimated")
  updatedAt   DateTime @updatedAt @map("updated_at")

  match       Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([matchId, market, selection])
  @@index([matchId])
  @@map("odds")
}

model Bet {
  id              String    @id @default(cuid())
  userId          String    @map("user_id")
  stake           Decimal   @db.Decimal(10, 2)
  totalOdds       Decimal   @map("total_odds") @db.Decimal(10, 2)
  potentialReturn Decimal   @map("potential_return") @db.Decimal(10, 2)
  status          String    @default("PENDING")
  createdAt       DateTime  @default(now()) @map("created_at")
  settledAt       DateTime? @map("settled_at")

  user            User            @relation(fields: [userId], references: [id])
  selections      BetSelection[]

  @@index([userId])
  @@index([status])
  @@map("bets")
}

model BetSelection {
  id          String   @id @default(cuid())
  betId       String   @map("bet_id")
  matchId     String   @map("match_id")
  market      String
  selection   String
  odds        Decimal  @db.Decimal(10, 2)
  won         Boolean?

  bet         Bet     @relation(fields: [betId], references: [id], onDelete: Cascade)
  match       Match   @relation(fields: [matchId], references: [id])

  @@map("bet_selections")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  type      String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notifications")
}
